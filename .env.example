# RetailApp — Database Connection Configuration
# Tạo file .env từ template này và điền giá trị thực

# Cloud PostgreSQL (Aiven/Supabase)
DATABASE_URL="postgres://user:password@host:port/dbname?sslmode=require"

# Schema name (mặc định: public)
SCHEMA_NAME="public"

# Port cho ứng dụng (mặc định: 3000)
PORT=3000
