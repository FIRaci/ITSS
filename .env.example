# === DATABASE ===
# Aiven PostgreSQL connection URL (bắt buộc)
# Lấy từ Aiven Console > Service > Overview > Connection information
DATABASE_URL="postgres://avnadmin:<your_password>@<your_host>.aivencloud.com:<port>/defaultdb?sslmode=require"

# Schema name (mặc định: public)
SCHEMA_NAME="public"

# Port cho ứng dụng (mặc định: 3000)
PORT=3000