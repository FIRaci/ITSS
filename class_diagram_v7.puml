' ==========================================
' ENTITY RELATIONSHIPS
' ==========================================
' User & Role
UserAccount "n" --> "1" Role

' ImportRequest
ImportRequest "1" *-- "1..*" RequestDetail
ImportRequest "1" --> "0..*" ChangeLog
RequestDetail "n" --> "1" Merchandise

' ChangeLog → RiskReport
ChangeLog "1" --> "0..1" RiskReport

' OverseasOrder
OverseasOrder "0..*" --> "1" Site
OverseasOrder "1" --> "0..*" AllocationItem
ImportRequest "1" --> "0..*" OverseasOrder

' Proposal & Approval
Proposal "0..*" --> "1" OverseasOrder
Proposal "1" --> "0..1" ApprovalRequest

' Site inventory
Site "1" *-- "1..*" SiteInventory
SiteInventory "n" --> "1" Merchandise

' Internal inventory
Inventory "1" --> "1" Merchandise

' Temporary inventory
TemporaryInventory "0..*" --> "1" OverseasOrder

' Discrepancy
DiscrepancyReport "0..1" --> "1" OverseasOrder

' Notification
NotificationEvent "0..*" --> "1" UserAccount

